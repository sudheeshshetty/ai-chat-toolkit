# Required — chat API key (Groq, OpenAI, etc.)
API_KEY=

# Required when embeddings use a different provider/key than chat (e.g. Groq chat + OpenAI embeddings)
EMBEDDING_API_KEY=

# Optional — defaults shown (uncomment to override)
# PROVIDER=groq
# MODEL=llama-3.3-70b-versatile
# PORT=3336
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# BASE_URL=              # chat API base URL (openai-compatible / ollama only)
# EMBEDDING_BASE_URL=    # embedding API base URL
# WEB_ORIGIN=http://localhost:5176
