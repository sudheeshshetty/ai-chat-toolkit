{
  "name": "ai-chat-toolkit-widget",
  "version": "0.1.4",
  "description": "Embeddable AI chat web component",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
