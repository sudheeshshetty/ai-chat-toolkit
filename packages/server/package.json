{
  "name": "ai-chat-toolkit-server",
  "version": "1.1.0",
  "description": "Plug-and-play AI chat backend for Express with LLM providers and tool calling",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "node --import tsx/esm --test src/orchestration/defaultOrchestrationPrompt.test.ts src/orchestration/langchain/LangChainAgentOrchestrator.test.ts"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "express": "^5.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "langchain": "^1.4.4",
    "zod": "^4.4.3"
  }
}
