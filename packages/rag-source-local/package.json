{
  "name": "ai-chat-toolkit-rag-source-local",
  "version": "1.0.0",
  "description": "Local filesystem source adapter for ai-chat-toolkit-rag",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "node --import tsx/esm --test src/localSource.test.ts"
  },
  "peerDependencies": {
    "ai-chat-toolkit-rag": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "ai-chat-toolkit-rag": "workspace:*",
    "tsup": "^8.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
